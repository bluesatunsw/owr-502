	(text "TPS62A switches on above 1.8V\nTherefore: \n\nln(1-1.8/3.3) = -t/RC\n\nTherefore: RC = -t/ln(1-1.8/3.3)\n\nRC T1 upper limit: 6ms\nRC T1 lower limit: 0.6ms\n\nTau_T1 = 1 ms\nTau(T1 + T2) = 1ms + (0.6 to 6ms)= 3.3ms"
		(exclude_from_sim no)
		(at 145.288 106.426 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c348be91-9a7b-42f9-8f4e-cefd680fad82")
	)
