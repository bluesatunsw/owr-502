	(text "AP7366-W5-7 switches on above 1V\nTherefore: \n\nln(1-1/3.3) = -t/RC\n\nTherefore: RC = -t/ln(1-1/3.3)\n\nRC T3 upper limit: 5.54ms\nRC T3 lower limit: 16.6ms\n\nTherefore: RC = 4.3 + (5.54 <-> 16.6)\n= 9.84ms\n= 20.9ms\n"
		(exclude_from_sim no)
		(at 311.15 57.404 0)
		(effects
